# ─────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Trading mode: must be explicitly set to 'live' for live orders.
# Any other value (including 'paper') routes to Alpaca paper endpoint.
TRADING_MODE=paper

# Alpaca Paper Trading API credentials
# Get these from: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=your_secret_key_here
