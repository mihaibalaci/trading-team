# ─────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Trading mode — selects the broker connector:
#   paper   → Alpaca paper trading (default, safe)
#   live    → Alpaca live trading  (requires ALPACA_LIVE_CONFIRMED=yes)
#   mt5     → MetaTrader 5 demo account
#   mt5live → MetaTrader 5 live account
TRADING_MODE=paper

# ── Alpaca credentials ────────────────────────────────────────────
# Get these from: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=your_secret_key_here

# Uncomment to enable Alpaca live trading (safety gate):
# ALPACA_LIVE_CONFIRMED=yes

# ── MetaTrader 5 credentials ──────────────────────────────────────
# Required when TRADING_MODE=mt5 or mt5live.
# MT5 terminal must be installed and running on the same Windows machine.
# The Python MetaTrader5 package does not support Linux natively.
#
# MT5_LOGIN=12345678            # integer account number from your broker
# MT5_PASSWORD=your_password
# MT5_SERVER=YourBroker-Demo    # server name shown in MT5 login screen
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe   # optional
# MT5_MAGIC=20250101            # optional — EA magic number (default: 20250101)
